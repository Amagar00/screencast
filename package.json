{
  "name": "screencast-desktop",
  "version": "1.0.0",
  "description": "ScreenCast Desktop - Receive phone screen on PC",
  "author": "Amagar00",
  "main": "src/main.js",
  "scripts": {
    "dev:react": "vite",
    "dev:electron": "electron .",
    "build": "vite build && electron-builder --win --x64"
  },
  "dependencies": {
    "qrcode": "1.5.3",
    "ws": "8.16.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.2.1",
    "electron": "29.1.0",
    "electron-builder": "23.6.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "vite": "5.1.4"
  },
  "build": {
    "appId": "com.screencast.desktop",
    "productName": "ScreenCast",
    "files": [
      "dist/**/*",
      "src/main.js",
      "src/preload.js"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable",
      "arch": ["x64"]
    }
  }
}
